            game.lastClickTime = now;
            if (game.combo > game.maxCombo) game.maxCombo = game.combo;

            clearTimeout(comboDecayTimer);
            comboDecayTimer = setTimeout(() => { game.combo = 0; updateComboDisplay(); }, 1200);
