                el.className = 'path-treat';
                el.textContent = treats[Math.floor(Math.random() * treats.length)];
                el.style.left = (5 + i * 9) + '%';
                el.style.bottom = (8 + Math.random() * 20) + '%';
                el.style.animationDelay = (Math.random() * 2) + 's';
                container.appendChild(el);
            }
        }

        function buildTreatWorldScene() {
            const container = document.getElementById('floatingTreats');
            container.innerHTML = '';
            const treats = ['🦴', '🍖', '🥩', '🍪', '🧁', '🎾', '🐾', '⭐'];
            for (let i = 0; i < 15; i++) {
                const el = document.createElement('div');
                el.className = 'floating-treat';
                el.textContent = treats[Math.floor(Math.random() * treats.length)];
                el.style.left = (5 + Math.random() * 90) + '%';
                el.style.top = (5 + Math.random() * 70) + '%';
                el.style.animationDelay = (Math.random() * 3) + 's';
                el.style.animationDuration = (3 + Math.random() * 3) + 's';
