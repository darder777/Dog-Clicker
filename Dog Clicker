        // ===== Multiplier System =====
        function getMultipliers() {
            let clickMulti = 1;
            let autoMulti = 1;
            let globalMulti = game.prestigeMulti;

            shopData.forEach(item => {
                const owned = game.upgrades[item.id] || 0;
                if (owned > 0) {
                    if (item.clickMultiplier) clickMulti *= item.clickMultiplier;
                    if (item.autoMultiplier) autoMulti *= item.autoMultiplier;
                    if (item.globalMultiplier) globalMulti *= item.globalMultiplier;
                }
            });

            milestones.forEach(m => {
                if (unlockedMilestones.has(m.at)) {
                    if (m.reward === 'auto') autoMulti *= m.value;
                    if (m.reward === 'all') { clickMulti *= m.value; autoMulti *= m.value; }
                }
            });

            if (powerUpState.frenzy && powerUpState.frenzy.active) clickMulti *= 7;
            if (powerUpState.rain && powerUpState.rain.active) autoMulti *= 3;

            globalMulti *= game.moodMultiplier;

            return { clickMulti, autoMulti, globalMulti };
        }

        function getMilestoneBonusClick() {
            let bonus = 0;
            milestones.forEach(m => {
                if (unlockedMilestones.has(m.at) && m.reward === 'click') bonus += m.value;
            });
            return bonus;
        }

        function recalcPerSecond() {
            let ps = 0;
            const { autoMulti, globalMulti } = getMultipliers();
            shopData.forEach(item => {
                const owned = game.upgrades[item.id] || 0;
                ps += item.perSec * owned;
            });
            game.perSecond = ps * autoMulti * globalMulti + (game.adminPerSecBonus || 0);
        }

        function recalcClickPower() {
            let cp = 1 + getMilestoneBonusClick();
            const { clickMulti, globalMulti } = getMultipliers();
            shopData.forEach(item => {
                const owned = game.upgrades[item.id] || 0;
                cp += item.perClick * owned;
            });
            game.clickPower = cp * clickMulti * globalMulti;
        }

        function getEffectiveClick() {
            return game.clickPower * getComboMultiplier();
        }

