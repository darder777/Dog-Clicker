<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dog Clicker</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700&display=swap');

        body {
            font-family: 'Nunito', 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            overflow-x: hidden;
            user-select: none;
        }

        /* Floating bones background */
        .bg-bone {
            position: fixed;
            font-size: 30px;
            opacity: 0.1;
            animation: floatBone 15s infinite linear;
            pointer-events: none;
            z-index: 0;
        }

        @keyframes floatBone {
            0% { transform: translateY(100vh) rotate(0deg); }
            100% { transform: translateY(-100px) rotate(360deg); }
        }

        /* Header */
        .header {
            text-align: center;
            padding: 20px;
            position: relative;
            z-index: 10;
        }

        .header h1 {
            font-family: 'Fredoka One', sans-serif;
            font-size: 3rem;
            color: #fff;
            text-shadow: 3px 3px 6px rgba(0,0,0,0.3);
            letter-spacing: 2px;
        }

        .header h1 span {
            display: inline-block;
            animation: bounce 0.6s ease infinite alternate;
        }

        @keyframes bounce {
            from { transform: translateY(0); }
            to { transform: translateY(-8px); }
        }

        /* Score Display */
        .score-panel {
            text-align: center;
            margin: 10px auto;
            position: relative;
            z-index: 10;
        }

        .score-main {
            font-family: 'Fredoka One', sans-serif;
            font-size: 2.8rem;
            color: #FFD700;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.4);
        }

        .score-per-sec {
            font-size: 1rem;
            color: rgba(255,255,255,0.8);
            margin-top: 2px;
        }

        /* Main Layout */
        .game-container {
            display: flex;
            justify-content: center;
            align-items: flex-start;
            gap: 30px;
            padding: 10px 20px 30px;
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
            flex-wrap: wrap;
        }

        /* Dog Click Area */
        .click-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }

        .dog-container {
            position: relative;
            width: 280px;
            height: 280px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .dog-btn {
            width: 240px;
            height: 240px;
            border-radius: 24px;
            border: 6px solid rgba(255,255,255,0.5);
            background: rgba(255,255,255,0.15);
            cursor: pointer;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
            box-shadow: 0 8px 30px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
            position: relative;
            overflow: hidden;
        }

        .dog-btn::after {
            content: '';
            position: absolute;
            top: 15%;
            left: 20%;
            width: 30%;
            height: 20%;
            background: rgba(255,255,255,0.4);
            border-radius: 50%;
            transform: rotate(-30deg);
        }

        .dog-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 40px rgba(0,0,0,0.4), inset 0 -4px 10px rgba(0,0,0,0.1);
        }

        .dog-btn:active {
            transform: scale(0.92);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3), inset 0 4px 10px rgba(0,0,0,0.15);
        }

        .dog-btn.clicked {
            animation: dogPop 0.15s ease;
        }

        @keyframes dogPop {
            0% { transform: scale(1); }
            50% { transform: scale(0.88); }
            100% { transform: scale(1); }
        }

        /* Click particles */
        .click-particle {
            position: absolute;
            font-weight: 700;
            font-size: 1.4rem;
            color: #FFD700;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
            pointer-events: none;
            animation: particleFly 1s ease-out forwards;
            z-index: 100;
        }

        @keyframes particleFly {
            0% { opacity: 1; transform: translateY(0) scale(1); }
            100% { opacity: 0; transform: translateY(-80px) scale(1.5); }
        }

        /* Click power display */
        .click-power {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            padding: 8px 20px;
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
        }

        /* Shop Panel */
        .shop-panel {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            padding: 20px;
            width: 340px;
            max-height: 520px;
            overflow-y: auto;
        }

        .shop-panel::-webkit-scrollbar {
            width: 6px;
        }

        .shop-panel::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
        }

        .shop-title {
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.5rem;
            color: #fff;
            text-align: center;
            margin-bottom: 15px;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        }

        .shop-item {
            background: rgba(255,255,255,0.12);
            border: 2px solid rgba(255,255,255,0.15);
            border-radius: 14px;
            padding: 14px 16px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .shop-item:hover {
            background: rgba(255,255,255,0.22);
            border-color: rgba(255,255,255,0.35);
            transform: translateX(4px);
        }

        .shop-item.cannot-afford {
            opacity: 0.45;
            cursor: not-allowed;
        }

        .shop-item.cannot-afford:hover {
            transform: none;
            background: rgba(255,255,255,0.12);
            border-color: rgba(255,255,255,0.15);
        }

        .shop-icon {
            font-size: 2.2rem;
            width: 50px;
            text-align: center;
            flex-shrink: 0;
        }

        .shop-info {
            flex: 1;
            min-width: 0;
        }

        .shop-name {
            font-weight: 700;
            color: #fff;
            font-size: 1rem;
        }

        .shop-desc {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.65);
            margin-top: 2px;
        }

        .shop-cost {
            font-family: 'Fredoka One', sans-serif;
            color: #FFD700;
            font-size: 0.95rem;
            margin-top: 4px;
        }

        .shop-owned {
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            padding: 3px 10px;
            color: rgba(255,255,255,0.8);
            font-size: 0.8rem;
            font-weight: 700;
            flex-shrink: 0;
            text-align: center;
            min-width: 32px;
        }

        /* Stats Panel */
        .stats-panel {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            padding: 20px;
            width: 220px;
        }

        .stats-title {
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.2rem;
            color: #fff;
            text-align: center;
            margin-bottom: 12px;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.85);
            font-size: 0.85rem;
        }

        .stat-row:last-child {
            border-bottom: none;
        }

        .stat-label {
            color: rgba(255,255,255,0.6);
        }

        .stat-value {
            font-weight: 700;
        }

        /* Achievements */
        .achievement-popup {
            position: fixed;
            top: 20px;
            right: -400px;
            background: linear-gradient(135deg, #FFD700, #FFA000);
            color: #333;
            padding: 16px 24px;
            border-radius: 14px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.3);
            z-index: 1000;
            transition: right 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            max-width: 300px;
        }

        .achievement-popup.show {
            right: 20px;
        }

        .achievement-popup h3 {
            font-family: 'Fredoka One', sans-serif;
            font-size: 1rem;
            margin-bottom: 4px;
        }

        .achievement-popup p {
            font-size: 0.85rem;
        }

        /* Reset button */
        .reset-btn {
            display: block;
            margin: 10px auto 0;
            background: rgba(255,70,70,0.3);
            border: 1px solid rgba(255,70,70,0.5);
            color: #ff9999;
            padding: 8px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s;
        }

        .reset-btn:hover {
            background: rgba(255,70,70,0.5);
            color: #fff;
        }

        /* Purchase flash */
        .purchase-flash {
            animation: flashGreen 0.4s ease;
        }

        @keyframes flashGreen {
            0% { border-color: rgba(255,255,255,0.15); }
            50% { border-color: #4CAF50; box-shadow: 0 0 20px rgba(76,175,80,0.4); }
            100% { border-color: rgba(255,255,255,0.15); }
        }

        /* Responsive */
        @media (max-width: 900px) {
            .game-container {
                flex-direction: column;
                align-items: center;
            }
            .shop-panel, .stats-panel {
                width: 90%;
                max-width: 400px;
            }
        }

        @media (max-width: 500px) {
            .header h1 {
                font-size: 2rem;
            }
            .score-main {
                font-size: 2rem;
            }
            .dog-btn {
                width: 180px;
                height: 180px;
                font-size: 90px;
            }
            .dog-container {
                width: 220px;
                height: 220px;
            }
        }

        /* ===== Mood Display ===== */
        .mood-display {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            padding: 6px 18px;
            color: #fff;
            font-weight: 700;
            font-size: 0.95rem;
            text-align: center;
            transition: all 0.3s;
        }

        /* ===== Combo Display ===== */
        .combo-display {
            position: absolute;
            top: -10px;
            right: -10px;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.5rem;
            color: #FFD700;
            text-shadow: 0 0 10px rgba(255,215,0,0.6), 2px 2px 4px rgba(0,0,0,0.5);
            pointer-events: none;
            z-index: 50;
            display: none;
            transition: all 0.15s;
        }

        /* ===== Power-Ups Bar ===== */
        .power-ups-bar {
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .power-up-btn {
            position: relative;
            background: rgba(255,255,255,0.12);
            border: 2px solid rgba(255,255,255,0.25);
            border-radius: 12px;
            padding: 8px 12px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            min-width: 90px;
            overflow: hidden;
            font-family: 'Nunito', sans-serif;
        }

        .power-up-btn:hover {
            background: rgba(255,255,255,0.25);
            transform: translateY(-2px);
        }

        .power-up-btn.active {
            background: rgba(76,175,80,0.3);
            border-color: #4CAF50;
            box-shadow: 0 0 15px rgba(76,175,80,0.4);
            animation: puPulse 1s infinite;
        }

        .power-up-btn.cooldown {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .power-up-btn.no-afford {
            opacity: 0.4;
            cursor: not-allowed;
        }

        @keyframes puPulse {
            0%, 100% { box-shadow: 0 0 15px rgba(76,175,80,0.4); }
            50% { box-shadow: 0 0 25px rgba(76,175,80,0.7); }
        }

        .pu-icon { font-size: 1.4rem; }
        .pu-name { font-size: 0.65rem; font-weight: 700; }
        .pu-status { font-size: 0.6rem; opacity: 0.8; }

        .pu-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            border-radius: 0 0 12px 12px;
            transition: width 0.3s linear;
        }

        /* ===== Golden Bone ===== */
        .golden-bone {
            position: fixed;
            font-size: 3.5rem;
            cursor: pointer;
            z-index: 500;
            display: none;
            filter: drop-shadow(0 0 15px rgba(255,215,0,0.8));
            transition: transform 0.1s;
        }

        .golden-bone:hover {
            transform: scale(1.3);
        }

        .golden-pulse {
            animation: goldenPulse 0.8s ease-in-out infinite;
        }

        @keyframes goldenPulse {
            0%, 100% { transform: scale(1) rotate(-5deg); filter: drop-shadow(0 0 15px rgba(255,215,0,0.8)); }
            50% { transform: scale(1.15) rotate(5deg); filter: drop-shadow(0 0 25px rgba(255,215,0,1)); }
        }

        @keyframes goldenRewardAnim {
            0% { opacity: 1; transform: translate(-50%, -50%) scale(0.5); }
            30% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
            100% { opacity: 0; transform: translate(-50%, -80%) scale(1.5); }
        }

        /* ===== Screen Shake ===== */
        .screen-shake {
            animation: shake 0.3s ease;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-4px); }
            80% { transform: translateX(4px); }
        }

        /* ===== Shop Category Tabs ===== */
        .shop-tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 12px;
        }

        .shop-tab {
            flex: 1;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            padding: 6px 4px;
            color: rgba(255,255,255,0.7);
            font-size: 0.75rem;
            font-weight: 700;
            cursor: pointer;
            text-align: center;
            transition: all 0.2s;
            font-family: 'Nunito', sans-serif;
        }

        .shop-tab:hover {
            background: rgba(255,255,255,0.2);
        }

        .shop-tab.active {
            background: rgba(255,255,255,0.25);
            border-color: rgba(255,255,255,0.4);
            color: #fff;
        }

        /* ===== Milestone Banner ===== */
        .milestone-banner {
            position: fixed;
            top: -80px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(135deg, #FFD700, #FF8C00);
            color: #333;
            padding: 14px 30px;
            border-radius: 0 0 16px 16px;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.1rem;
            box-shadow: 0 8px 30px rgba(255,140,0,0.5);
            z-index: 1001;
            transition: top 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            text-align: center;
            white-space: nowrap;
        }

        .milestone-banner.show {
            top: 0;
        }

        /* ===== Treat Rain Effect ===== */
        .treat-rain-particle {
            position: fixed;
            font-size: 1.5rem;
            pointer-events: none;
            z-index: 499;
            animation: treatFall 2s linear forwards;
        }

        @keyframes treatFall {
            0% { opacity: 1; transform: translateY(-20px) rotate(0deg); }
            100% { opacity: 0; transform: translateY(100vh) rotate(360deg); }
        }

        /* ===== Shop item production info ===== */
        .shop-production {
            font-size: 0.7rem;
            color: rgba(255,215,0,0.7);
            margin-top: 2px;
        }

        /* ===== Prestige / Rebirth Button ===== */
        .prestige-btn {
            display: none;
            margin: 8px auto;
            background: linear-gradient(135deg, #9b59b6, #8e44ad);
            border: 2px solid #bb6bd9;
            color: #fff;
            padding: 10px 20px;
            border-radius: 12px;
            cursor: pointer;
            font-family: 'Fredoka One', sans-serif;
            font-size: 0.9rem;
            transition: all 0.3s;
            text-align: center;
            box-shadow: 0 4px 15px rgba(155,89,182,0.4);
        }

        .prestige-btn:hover {
            background: linear-gradient(135deg, #bb6bd9, #9b59b6);
            transform: scale(1.05);
            box-shadow: 0 6px 25px rgba(155,89,182,0.6);
        }

        .prestige-info {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.6);
            text-align: center;
            margin-top: 4px;
        }

        /* ===== Boss Fight ===== */
        .boss-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.85);
            z-index: 2000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .boss-overlay.active {
            display: flex;
        }

        .boss-title {
            font-family: 'Fredoka One', sans-serif;
            font-size: 2rem;
            color: #ff4444;
            text-shadow: 0 0 20px rgba(255,68,68,0.6);
            animation: bossTitlePulse 1s infinite;
        }

        @keyframes bossTitlePulse {
            0%, 100% { text-shadow: 0 0 20px rgba(255,68,68,0.6); }
            50% { text-shadow: 0 0 40px rgba(255,68,68,1); }
        }

        .boss-sprite {
            font-size: 8rem;
            animation: bossIdle 1s ease-in-out infinite;
            cursor: pointer;
            transition: transform 0.05s;
            filter: drop-shadow(0 0 20px rgba(255,0,0,0.5));
        }

        .boss-sprite:active {
            transform: scale(0.9);
        }

        @keyframes bossIdle {
            0%, 100% { transform: translateY(0) rotate(-2deg); }
            50% { transform: translateY(-10px) rotate(2deg); }
        }

        .boss-hp-bar {
            width: 300px;
            height: 20px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .boss-hp-fill {
            height: 100%;
            background: linear-gradient(90deg, #ff4444, #ff6666);
            border-radius: 10px;
            transition: width 0.15s;
        }

        .boss-hp-text {
            color: #fff;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .boss-timer {
            color: #ffaa00;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .boss-reward-text {
            color: #FFD700;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.5rem;
        }

        .boss-hit {
            animation: bossHit 0.15s ease;
        }

        @keyframes bossHit {
            0% { transform: scale(1); filter: drop-shadow(0 0 20px rgba(255,0,0,0.5)); }
            50% { transform: scale(0.85); filter: drop-shadow(0 0 40px rgba(255,255,0,1)) brightness(2); }
            100% { transform: scale(1); filter: drop-shadow(0 0 20px rgba(255,0,0,0.5)); }
        }

        /* ===== Mini-Game: Treat Catch ===== */
        .minigame-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.9);
            z-index: 2000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .minigame-overlay.active {
            display: flex;
        }

        .minigame-area {
            position: relative;
            width: 400px;
            height: 400px;
            background: linear-gradient(180deg, #1a1a3e, #2d1b69);
            border-radius: 20px;
            border: 3px solid rgba(255,255,255,0.2);
            overflow: hidden;
        }

        .minigame-title {
            font-family: 'Fredoka One', sans-serif;
            color: #fff;
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .minigame-score {
            color: #FFD700;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.2rem;
            margin-top: 10px;
        }

        .minigame-timer {
            color: #ffaa00;
            font-weight: 700;
            margin-top: 5px;
        }

        .falling-treat {
            position: absolute;
            font-size: 2rem;
            cursor: pointer;
            transition: transform 0.1s;
            z-index: 10;
        }

        .falling-treat:hover {
            transform: scale(1.3);
        }

        .falling-bomb {
            position: absolute;
            font-size: 2rem;
            cursor: pointer;
            z-index: 10;
        }

        /* ===== Win Screen / Endgame ===== */
        .win-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(ellipse at center, #1a0a2e 0%, #0d0015 60%, #000 100%);
            z-index: 3000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 14px;
            overflow: hidden;
        }

        .win-overlay.active {
            display: flex;
            animation: winFadeIn 1.2s ease-out;
        }

        @keyframes winFadeIn {
            0% { opacity: 0; }
            100% { opacity: 1; }
        }

        .win-fireworks-canvas {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .win-confetti-container {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 1;
            overflow: hidden;
        }

        .confetti-piece {
            position: absolute;
            top: -20px;
            width: 10px;
            height: 14px;
            border-radius: 2px;
            animation: confettiFall linear forwards;
        }

        @keyframes confettiFall {
            0% { transform: translateY(0) rotateZ(0deg) rotateX(0deg); opacity: 1; }
            75% { opacity: 1; }
            100% { transform: translateY(105vh) rotateZ(720deg) rotateX(360deg); opacity: 0; }
        }

        .win-content {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
        }

        .win-dog {
            font-size: 7rem;
            opacity: 0;
            transform: scale(0) rotate(-180deg);
            animation: winDogEntrance 1.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.5s forwards,
                       winDogFloat 3s ease-in-out 2s infinite;
            filter: drop-shadow(0 0 30px rgba(255, 215, 0, 0.6));
        }

        .win-dog img {
            width: 140px;
            height: 140px;
            object-fit: contain;
            border-radius: 50%;
            border: 4px solid #FFD700;
            box-shadow: 0 0 40px rgba(255, 215, 0, 0.5);
        }

        .win-crown {
            position: absolute;
            top: -30px;
            font-size: 3rem;
            animation: crownBob 2s ease-in-out 2s infinite;
            filter: drop-shadow(0 0 15px rgba(255, 215, 0, 0.8));
            opacity: 0;
            animation: crownAppear 0.8s ease 1.8s forwards, crownBob 2s ease-in-out 2.6s infinite;
        }

        @keyframes winDogEntrance {
            0% { opacity: 0; transform: scale(0) rotate(-180deg); }
            60% { opacity: 1; transform: scale(1.3) rotate(10deg); }
            80% { transform: scale(0.95) rotate(-5deg); }
            100% { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        @keyframes winDogFloat {
            0%, 100% { transform: translateY(0) rotate(-2deg); }
            50% { transform: translateY(-15px) rotate(2deg); }
        }

        @keyframes crownAppear {
            0% { opacity: 0; transform: translateY(-40px) scale(0); }
            70% { opacity: 1; transform: translateY(5px) scale(1.2); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        @keyframes crownBob {
            0%, 100% { transform: translateY(0) rotate(-3deg); }
            50% { transform: translateY(-8px) rotate(3deg); }
        }

        .win-title {
            font-family: 'Fredoka One', sans-serif;
            font-size: 3.2rem;
            background: linear-gradient(90deg, #FFD700, #FF8C00, #FF6347, #FF69B4, #9370DB, #00BFFF, #FFD700);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: winTitleSlideIn 1s cubic-bezier(0.34, 1.56, 0.64, 1) 1s forwards,
                       rainbowText 4s linear 2s infinite;
            opacity: 0;
            transform: translateY(50px);
            filter: drop-shadow(0 0 20px rgba(255,215,0,0.5));
            text-align: center;
        }

        @keyframes winTitleSlideIn {
            0% { opacity: 0; transform: translateY(50px) scale(0.5); }
            60% { opacity: 1; transform: translateY(-10px) scale(1.1); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        @keyframes rainbowText {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }

        .win-subtitle {
            font-size: 1.15rem;
            color: rgba(255,255,255,0.9);
            text-align: center;
            max-width: 460px;
            line-height: 1.6;
            opacity: 0;
            animation: winFadeSlideUp 0.8s ease 1.6s forwards;
            text-shadow: 0 0 20px rgba(255,255,255,0.3);
        }

        @keyframes winFadeSlideUp {
            0% { opacity: 0; transform: translateY(30px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .win-stats {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 18px 36px;
            color: #fff;
            text-align: center;
            opacity: 0;
            animation: winStatsReveal 0.8s ease 2.2s forwards;
            box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 0 30px rgba(255,255,255,0.05);
        }

        @keyframes winStatsReveal {
            0% { opacity: 0; transform: translateY(40px) scale(0.9); }
            100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .win-stats h3 {
            font-family: 'Fredoka One', sans-serif;
            margin-bottom: 10px;
            color: #FFD700;
        }

        .win-stats p {
            margin: 5px 0;
            font-size: 0.95rem;
            opacity: 0;
            animation: statLineReveal 0.4s ease forwards;
        }

        @keyframes statLineReveal {
            0% { opacity: 0; transform: translateX(-20px); }
            100% { opacity: 1; transform: translateX(0); }
        }

        .win-buttons {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            justify-content: center;
            opacity: 0;
            animation: winFadeSlideUp 0.8s ease 3.5s forwards;
        }

        .win-btn {
            background: linear-gradient(135deg, rgba(255,215,0,0.3), rgba(255,140,0,0.3));
            border: 2px solid rgba(255,215,0,0.5);
            color: #fff;
            padding: 14px 32px;
            border-radius: 16px;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
        }

        .win-btn::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: conic-gradient(transparent, rgba(255,255,255,0.1), transparent, rgba(255,255,255,0.1), transparent);
            animation: winBtnGlow 3s linear infinite;
        }

        @keyframes winBtnGlow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .win-btn:hover {
            background: linear-gradient(135deg, rgba(255,215,0,0.5), rgba(255,140,0,0.5));
            transform: scale(1.08) translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,215,0,0.3);
        }

        .win-btn span {
            position: relative;
            z-index: 1;
        }

        /* sparkle particles around win screen */
        .win-sparkle {
            position: absolute;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #FFD700;
            pointer-events: none;
            z-index: 1;
            animation: sparkleDrift 3s ease-in-out infinite;
        }

        @keyframes sparkleDrift {
            0%, 100% { opacity: 0; transform: scale(0) translateY(0); }
            50% { opacity: 1; transform: scale(1) translateY(-30px); }
        }

        /* golden rays behind the dog */
        .win-rays {
            position: absolute;
            width: 400px;
            height: 400px;
            z-index: 0;
            animation: raysRotate 20s linear infinite;
            opacity: 0;
            animation: raysFadeIn 2s ease 0.3s forwards, raysRotate 20s linear 2s infinite;
        }

        @keyframes raysFadeIn {
            0% { opacity: 0; }
            100% { opacity: 0.3; }
        }

        @keyframes raysRotate {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* ===== Progress Bar (endgame) ===== */
        .progress-bar-container {
            width: 90%;
            max-width: 700px;
            margin: 5px auto;
            position: relative;
            z-index: 10;
            text-align: center;
        }

        .progress-label {
            color: rgba(255,255,255,0.6);
            font-size: 0.75rem;
            margin-bottom: 3px;
        }

        .progress-track {
            height: 10px;
            background: rgba(255,255,255,0.1);
            border-radius: 5px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.15);
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #FFD700, #ff6347);
            border-radius: 5px;
            transition: width 0.5s;
            background-size: 200%;
            animation: progressShimmer 3s linear infinite;
        }

        @keyframes progressShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ===== Event Button ===== */
        .event-btn {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 10px;
            padding: 6px 14px;
            color: rgba(255,255,255,0.7);
            font-size: 0.8rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            margin: 4px 2px;
            font-family: 'Nunito', sans-serif;
        }

        .event-btn:hover {
            background: rgba(255,255,255,0.25);
            color: #fff;
        }

        .event-btn.disabled-btn {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .events-row {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 6px;
            margin-top: 8px;
        }

        /* ===== Auth / Login Screen ===== */
        .login-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            z-index: 5000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        .login-overlay.hidden { display: none; }

        .login-box {
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 24px;
            padding: 40px 36px;
            width: 380px;
            max-width: 90vw;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .login-box h2 {
            font-family: 'Fredoka One', sans-serif;
            color: #FFD700;
            font-size: 2rem;
            margin-bottom: 6px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .login-box .login-subtitle {
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
            margin-bottom: 24px;
        }

        .login-box input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            color: #fff;
            font-family: 'Nunito', sans-serif;
            font-size: 1rem;
            margin-bottom: 12px;
            outline: none;
            transition: border-color 0.3s;
        }

        .login-box input::placeholder { color: rgba(255,255,255,0.4); }
        .login-box input:focus { border-color: #FFD700; }

        .login-btn {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 8px;
        }

        .login-btn.primary {
            background: linear-gradient(135deg, #FFD700, #FF8C00);
            color: #333;
        }

        .login-btn.secondary {
            background: rgba(255,255,255,0.15);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .login-btn:hover { transform: scale(1.03); filter: brightness(1.1); }

        .login-error {
            color: #ff6b6b;
            font-size: 0.85rem;
            margin-top: 8px;
            min-height: 20px;
        }

        .login-toggle {
            color: rgba(255,255,255,0.6);
            font-size: 0.85rem;
            margin-top: 14px;
        }

        .login-toggle a {
            color: #FFD700;
            cursor: pointer;
            text-decoration: underline;
        }

        /* User bar at top */
        .user-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            background: rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
            padding: 6px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.9);
        }

        .user-bar.hidden { display: none; }

        .user-bar .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .user-bar .user-info .username {
            font-family: 'Fredoka One', sans-serif;
            color: #FFD700;
        }

        .user-bar .admin-badge {
            background: #ff4444;
            color: #fff;
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        .user-bar button {
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.25);
            color: #fff;
            padding: 4px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Nunito', sans-serif;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .user-bar button:hover { background: rgba(255,255,255,0.25); }

        .header { margin-top: 35px; }

        /* Admin Panel */
        .admin-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 4000;
            align-items: center;
            justify-content: center;
        }

        .admin-overlay.active { display: flex; }

        .admin-panel {
            background: #1a1a2e;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 30px;
            width: 500px;
            max-width: 90vw;
            max-height: 80vh;
            overflow-y: auto;
            color: #fff;
        }

        .admin-panel h2 {
            font-family: 'Fredoka One', sans-serif;
            color: #ff4444;
            margin-bottom: 16px;
        }

        .admin-panel .admin-user {
            background: rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .admin-panel .admin-user .au-name {
            font-family: 'Fredoka One', sans-serif;
            color: #FFD700;
        }

        .admin-panel .admin-user .au-stats {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.5);
        }

        .admin-panel button {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 6px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .admin-panel button:hover { background: rgba(255,255,255,0.2); }
        .admin-panel button.danger { border-color: #ff4444; color: #ff4444; }
        .admin-panel button.danger:hover { background: rgba(255,68,68,0.2); }

        .admin-tools {
            background: rgba(255,140,0,0.08);
            border: 1px solid rgba(255,140,0,0.2);
            border-radius: 14px;
            padding: 16px;
            margin-bottom: 12px;
        }

        .admin-tool-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .admin-tool-row label {
            color: rgba(255,255,255,0.7);
            font-size: 0.85rem;
            min-width: 100px;
        }

        .admin-tool-row input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 6px 10px;
            border-radius: 8px;
            font-family: 'Nunito', sans-serif;
            font-size: 0.9rem;
            outline: none;
        }

        .admin-tool-row input:focus { border-color: #FFD700; }

        /* ===== Treat World Journey Cinematic ===== */
        .journey-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: 4500;
            overflow: hidden;
        }

        .journey-overlay.active { display: block; }

        .journey-scene {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            opacity: 0;
            transition: opacity 1s ease;
        }

        .journey-scene.visible { opacity: 1; }

        .journey-scene-bg {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
        }

        /* Scene 1: Linda's Home — warm cozy room */
        .scene-city .journey-scene-bg {
            background: linear-gradient(180deg, #2c1810 0%, #3e2723 30%, #4e342e 60%, #5d4037 100%);
        }

        .scene-city .city-buildings {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 40%;
            background: linear-gradient(180deg, #6d4c41, #5d4037);
            border-radius: 20px 20px 0 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 30px;
            padding: 0 20px;
        }

        .scene-city .treat-jar {
            font-size: 4rem;
            animation: treatJarGlow 2s ease-in-out infinite;
        }

        @keyframes treatJarGlow {
            0%, 100% { filter: brightness(1); transform: scale(1); }
            50% { filter: brightness(1.3); transform: scale(1.1); }
        }

        .scene-city .home-window {
            position: absolute;
            top: 15%;
            width: 120px; height: 100px;
            border: 6px solid #8D6E63;
            border-radius: 8px;
            background: linear-gradient(180deg, #1a237e 0%, #283593 100%);
            box-shadow: 0 0 30px rgba(255,230,100,0.2);
        }

        .scene-city .home-window.left { left: 15%; }
        .scene-city .home-window.right { right: 15%; }

        .scene-city .stars {
            position: absolute;
            top: 0; left: 0; right: 0; height: 60%;
        }

        .scene-city .star {
            position: absolute;
            width: 3px; height: 3px;
            background: #FFD700;
            border-radius: 50%;
            animation: starTwinkle 2s ease-in-out infinite;
        }

        @keyframes starTwinkle {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        /* Scene 2: Treat trail path on the ground */
        .scene-clouds .journey-scene-bg {
            background: linear-gradient(180deg, #87CEEB 0%, #B0E0FF 25%, #90EE90 60%, #228B22 75%, #1B5E20 100%);
        }

        .scene-clouds .treat-path {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 35%;
            background: linear-gradient(180deg, #8B6914, #A0782C);
            border-radius: 30px 30px 0 0;
        }

        .scene-clouds .cloud {
            position: absolute;
            background: rgba(255,255,255,0.7);
            border-radius: 50px;
            box-shadow: 0 5px 30px rgba(255,255,255,0.5);
            animation: cloudDrift 8s ease-in-out infinite;
        }

        .scene-clouds .path-treat {
            position: absolute;
            font-size: 2rem;
            animation: pathTreatGlow 2s ease-in-out infinite;
        }

        @keyframes pathTreatGlow {
            0%, 100% { transform: scale(1); filter: brightness(1); }
            50% { transform: scale(1.15); filter: brightness(1.3); }
        }

        @keyframes cloudDrift {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(30px); }
        }

        /* Scene 3: Treat World gates — bone-shaped arch */
        .scene-gates .journey-scene-bg {
            background: linear-gradient(180deg, #FFF8E1 0%, #FFE0B2 40%, #FFB74D 70%, #FF9800 100%);
        }

        .scene-gates .gate-ground {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 30%;
            background: linear-gradient(180deg, #A0782C, #8B6914);
            border-radius: 30px 30px 0 0;
        }

        .gate-structure {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .gate-arch {
            width: 240px;
            height: 140px;
            border: 8px solid #FFCC80;
            border-bottom: none;
            border-radius: 120px 120px 0 0;
            box-shadow: 0 0 40px rgba(255, 152, 0, 0.6), inset 0 0 30px rgba(255, 183, 77, 0.3);
            position: relative;
            background: rgba(255, 224, 178, 0.15);
        }

        .gate-bone-decor {
            position: absolute;
            font-size: 2rem;
        }

        .gate-bone-decor.tl { top: 10px; left: 10px; }
        .gate-bone-decor.tr { top: 10px; right: 10px; }

        .gate-pillar {
            display: flex;
            justify-content: space-between;
            width: 256px;
        }

        .gate-pillar div {
            width: 16px;
            height: 100px;
            background: linear-gradient(180deg, #FFCC80, #FF9800);
            box-shadow: 0 0 20px rgba(255,152,0,0.4);
            border-radius: 4px;
        }

        .gate-text {
            position: absolute;
            top: 40%;
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.2rem;
            color: #E65100;
            text-shadow: 0 0 20px rgba(255,152,0,0.8);
        }

        .gate-glow {
            position: absolute;
            width: 350px; height: 350px;
            background: radial-gradient(circle, rgba(255,183,77,0.4), transparent 70%);
            border-radius: 50%;
            animation: gateGlow 2s ease-in-out infinite;
        }

        @keyframes gateGlow {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 0.8; }
        }

        /* Scene 4: Treat World */
        .scene-paradise .journey-scene-bg {
            background: linear-gradient(180deg, #FFE4B5 0%, #FFDAB9 25%, #FFB347 50%, #FF8C42 75%, #D2691E 100%);
        }

        .paradise-island {
            position: absolute;
            bottom: 15%;
            z-index: 2;
        }

        .island-base {
            width: 300px;
            height: 80px;
            background: linear-gradient(180deg, #DEB887, #D2B48C);
            border-radius: 50%;
            position: relative;
            box-shadow: 0 5px 30px rgba(210,105,30,0.3);
        }

        .treat-decoration {
            position: absolute;
            bottom: 60px;
            font-size: 2.5rem;
            animation: treatBob 2s ease-in-out infinite;
        }

        @keyframes treatBob {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .paradise-water {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 12%;
            background: linear-gradient(180deg, rgba(255,179,71,0.6), rgba(210,105,30,0.4));
            animation: waterWave 3s ease-in-out infinite;
        }

        .floating-treats {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .floating-treat {
            position: absolute;
            font-size: 2rem;
            animation: floatTreat 4s ease-in-out infinite;
            opacity: 0.7;
        }

        @keyframes floatTreat {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(15deg); }
        }

        @keyframes waterWave {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        /* Dog walking/flying in journey */
        .journey-dog {
            position: absolute;
            z-index: 10;
            transition: left 2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        top 2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                        bottom 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            transform: translateX(-50%);
        }

        .journey-dog img {
            width: 100px;
            height: 100px;
            object-fit: contain;
            border-radius: 50%;
            border: 3px solid #FFD700;
            box-shadow: 0 0 30px rgba(255,215,0,0.5);
        }

        .journey-dog.walking {
            animation: dogWalk 0.4s ease-in-out infinite;
        }

        .journey-dog.flying {
            animation: dogFly 1.5s ease-in-out infinite;
        }

        @keyframes dogWalk {
            0%, 100% { transform: translateX(-50%) translateY(0) rotate(-2deg); }
            50% { transform: translateX(-50%) translateY(-8px) rotate(2deg); }
        }

        @keyframes dogFly {
            0%, 100% { transform: translateX(-50%) translateY(0) rotate(-3deg); }
            50% { transform: translateX(-50%) translateY(-20px) rotate(3deg); }
        }

        .journey-dog .wings {
            position: absolute;
            top: 10px;
            font-size: 2rem;
            animation: wingFlap 0.3s ease-in-out infinite;
            display: none;
        }

        .journey-dog .wings.left { left: -25px; }
        .journey-dog .wings.right { right: -25px; transform: scaleX(-1); }

        .journey-dog.flying .wings { display: block; }

        @keyframes wingFlap {
            0%, 100% { transform: rotate(-20deg) scaleX(1); }
            50% { transform: rotate(20deg) scaleX(1); }
        }

        .journey-dog.flying .wings.right {
            animation: wingFlapR 0.3s ease-in-out infinite;
        }

        @keyframes wingFlapR {
            0%, 100% { transform: scaleX(-1) rotate(-20deg); }
            50% { transform: scaleX(-1) rotate(20deg); }
        }

        /* Journey text captions */
        .journey-caption {
            position: absolute;
            bottom: 12%;
            left: 50%;
            transform: translateX(-50%);
            font-family: 'Fredoka One', sans-serif;
            font-size: 1.8rem;
            color: #fff;
            text-shadow: 0 0 30px rgba(0,0,0,0.5), 2px 2px 4px rgba(0,0,0,0.5);
            opacity: 0;
            transition: opacity 0.8s ease;
            text-align: center;
            white-space: nowrap;
            z-index: 20;
        }

        .journey-caption.visible { opacity: 1; }

        .journey-trail {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            z-index: 5;
            animation: trailFade 1s ease-out forwards;
        }

        @keyframes trailFade {
            0% { opacity: 0.8; transform: scale(1); }
            100% { opacity: 0; transform: scale(0); }
        }
    </style>
