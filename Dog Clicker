        // ===== Main Game Loop =====
        let lastTick = Date.now();
        let shopUpdateTimer = 0;
        let powerUpRenderTimer = 0;
        let progressTimer = 0;

        function gameLoop() {
            const now = Date.now();
            const delta = (now - lastTick) / 1000;
            lastTick = now;

            if (game.perSecond > 0) {
                const earned = game.perSecond * delta;
                game.treats += earned;
                game.totalTreats += earned;
                game.lifetimeTreats += earned;
            }

            autoClickTick(delta);
            tickPowerUps(delta);
            updateDisplay();

            shopUpdateTimer += delta;
            if (shopUpdateTimer >= 0.5) {
                shopUpdateTimer = 0;
                updateShopAffordability();
                checkAchievements();
                checkMilestones();
                updateMood();
                checkWinCondition();
            }

            powerUpRenderTimer += delta;
            if (powerUpRenderTimer >= 0.3) {
                powerUpRenderTimer = 0;
                renderPowerUps();
                renderPrestige();
            }

            progressTimer += delta;
            if (progressTimer >= 1) {
                progressTimer = 0;
                updateProgressBar();
                renderEvents();
            }

            requestAnimationFrame(gameLoop);
        }

