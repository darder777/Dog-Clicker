        function activatePowerUp(powerUp) {
            const state = powerUpState[powerUp.id];
            if (state.active || state.cooldown > 0 || game.treats < powerUp.cost) return;
            game.treats -= powerUp.cost;
            state.active = true;
            state.remaining = powerUp.duration;
            game.powerUpsUsed++;
            if (powerUp.id === 'rain') spawnTreatRain(15);
            playBuySound();
            recalcPerSecond();
            recalcClickPower();
            updateDisplay();
            renderPowerUps();
            checkAchievements();
            saveGame();
