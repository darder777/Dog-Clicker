        function startJourneyTrail(dog) {
            journeyTrailInterval = setInterval(() => {
                const rect = dog.getBoundingClientRect();
                const trail = document.createElement('div');
                trail.className = 'journey-trail';
                const colors = ['#FFD700', '#FF69B4', '#00BFFF', '#FFF'];
                trail.style.background = colors[Math.floor(Math.random() * colors.length)];
                trail.style.width = (4 + Math.random() * 8) + 'px';
                trail.style.height = trail.style.width;
                trail.style.left = (rect.left + rect.width / 2 + (Math.random() - 0.5) * 30) + 'px';
                trail.style.top = (rect.top + rect.height / 2 + (Math.random() - 0.5) * 30) + 'px';
                document.getElementById('journeyOverlay').appendChild(trail);
                setTimeout(() => trail.remove(), 1000);
            }, 60);
        }

        function stopJourneyTrail() {
            if (journeyTrailInterval) { clearInterval(journeyTrailInterval); journeyTrailInterval = null; }
        }

        // ===== Win Screen Animations =====
        let fireworksRAF = null;
        let confettiInterval = null;
        let sparkleInterval = null;

        function startWinAnimations() {
            startFireworks();
            startConfetti();
            startSparkles();
        }

        function stopWinAnimations() {
            if (fireworksRAF) { cancelAnimationFrame(fireworksRAF); fireworksRAF = null; }
            if (confettiInterval) { clearInterval(confettiInterval); confettiInterval = null; }
            if (sparkleInterval) { clearInterval(sparkleInterval); sparkleInterval = null; }
            stopJourneyTrail();
            const canvas = document.getElementById('fireworksCanvas');
            if (canvas) { const ctx = canvas.getContext('2d'); ctx.clearRect(0, 0, canvas.width, canvas.height); }
            const cc = document.getElementById('confettiContainer');
            if (cc) cc.innerHTML = '';
            document.querySelectorAll('.win-sparkle').forEach(s => s.remove());
            // Clean up journey overlay
            const jo = document.getElementById('journeyOverlay');
            if (jo) {
                jo.classList.remove('active');
                jo.style.opacity = '';
                jo.style.transition = '';
                jo.querySelectorAll('.journey-scene').forEach(s => s.classList.remove('visible'));
                jo.querySelectorAll('.journey-caption').forEach(c => c.classList.remove('visible'));
                jo.querySelectorAll('.journey-trail').forEach(t => t.remove());
            }
        }

        // -- Fireworks --
        function startFireworks() {
            const canvas = document.getElementById('fireworksCanvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            const fireworks = [];
            const particles = [];
            const colors = ['#FFD700','#FF6347','#FF69B4','#00BFFF','#7CFC00','#FF8C00','#9370DB','#00FFCC'];

            function Firework() {
                this.x = Math.random() * canvas.width;
                this.y = canvas.height;
                this.targetY = canvas.height * (0.15 + Math.random() * 0.4);
                this.speed = 4 + Math.random() * 3;
                this.color = colors[Math.floor(Math.random() * colors.length)];
                this.trail = [];
                this.alive = true;
            }

            function Particle(x, y, color) {
                this.x = x;
                this.y = y;
                const angle = Math.random() * Math.PI * 2;
                const speed = 1 + Math.random() * 5;
                this.vx = Math.cos(angle) * speed;
                this.vy = Math.sin(angle) * speed;
                this.color = color;
                this.alpha = 1;
                this.decay = 0.012 + Math.random() * 0.02;
                this.size = 1.5 + Math.random() * 2;
            }

            function spawnFirework() {
                fireworks.push(new Firework());
            }

            function explode(fw) {
                const count = 60 + Math.floor(Math.random() * 40);
                for (let i = 0; i < count; i++) particles.push(new Particle(fw.x, fw.y, fw.color));
                playSound(300 + Math.random() * 400, 0.3, 'sine', 0.04);
            }

            let lastSpawn = 0;
            function animate(time) {
                ctx.globalCompositeOperation = 'destination-out';
                ctx.fillStyle = 'rgba(0,0,0,0.15)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.globalCompositeOperation = 'lighter';

                if (time - lastSpawn > 400 + Math.random() * 600) { spawnFirework(); lastSpawn = time; }

                for (let i = fireworks.length - 1; i >= 0; i--) {
                    const fw = fireworks[i];
                    fw.trail.push({ x: fw.x, y: fw.y });
                    if (fw.trail.length > 8) fw.trail.shift();
                    fw.y -= fw.speed;
                    fw.x += (Math.random() - 0.5) * 0.5;

                    fw.trail.forEach((t, ti) => {
                        ctx.beginPath();
                        ctx.arc(t.x, t.y, 1.5, 0, Math.PI * 2);
                        ctx.fillStyle = fw.color;
                        ctx.globalAlpha = ti / fw.trail.length * 0.6;
                        ctx.fill();
                    });
                    ctx.globalAlpha = 1;

                    ctx.beginPath();
                    ctx.arc(fw.x, fw.y, 3, 0, Math.PI * 2);
                    ctx.fillStyle = '#fff';
                    ctx.fill();

                    if (fw.y <= fw.targetY) { explode(fw); fireworks.splice(i, 1); }
                }

                for (let i = particles.length - 1; i >= 0; i--) {
                    const p = particles[i];
                    p.x += p.vx;
                    p.y += p.vy;
                    p.vy += 0.04;
                    p.vx *= 0.99;
                    p.alpha -= p.decay;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    ctx.fillStyle = p.color;
                    ctx.globalAlpha = Math.max(0, p.alpha);
                    ctx.fill();

                    if (p.alpha <= 0) particles.splice(i, 1);
                }
                ctx.globalAlpha = 1;

                fireworksRAF = requestAnimationFrame(animate);
            }
            fireworksRAF = requestAnimationFrame(animate);
        }

