        function tickPowerUps(delta) {
            let needsRecalc = false;
            powerUps.forEach(p => {
                const state = powerUpState[p.id];
                if (!state) return;
                if (state.active) {
                    state.remaining -= delta;
                    if (state.remaining <= 0) {
                        state.active = false;
                        state.remaining = 0;
                        state.cooldown = p.cooldown * getCooldownMulti();
                        needsRecalc = true;
                    }
                } else if (state.cooldown > 0) {
                    state.cooldown = Math.max(0, state.cooldown - delta);
                }
            });
            if (needsRecalc) { recalcPerSecond(); recalcClickPower(); }
        }

        function renderPowerUps() {
            const container = document.getElementById('powerUpsBar');
            container.innerHTML = '';
            let anyVisible = false;
            powerUps.forEach(p => {
                if (game.totalTreats < p.unlockAt && game.lifetimeTreats < p.unlockAt) return;
                anyVisible = true;
                const state = powerUpState[p.id];
                if (!state) return;
                const canAfford = game.treats >= p.cost;
                const btn = document.createElement('button');
                let cls = 'power-up-btn';
                if (state.active) cls += ' active';
                else if (state.cooldown > 0) cls += ' cooldown';
                else if (!canAfford) cls += ' no-afford';
                btn.className = cls;

                let statusText = '';
                if (state.active) statusText = Math.ceil(state.remaining) + 's';
                else if (state.cooldown > 0) statusText = Math.ceil(state.cooldown) + 's CD';
                else statusText = '🦴' + formatNumber(p.cost);

                btn.innerHTML = '<span class="pu-icon">' + p.icon + '</span><span class="pu-name">' + p.name + '</span><span class="pu-status">' + statusText + '</span>';
                btn.title = p.desc;
                btn.onclick = () => activatePowerUp(p);

                if (state.active || state.cooldown > 0) {
                    const bar = document.createElement('div');
                    bar.className = 'pu-progress';
                    const effCD = p.cooldown * getCooldownMulti();
                    const pct = state.active ? (state.remaining / p.duration * 100) : ((effCD - state.cooldown) / effCD * 100);
                    bar.style.width = pct + '%';
                    bar.style.background = state.active ? 'rgba(76,175,80,0.5)' : 'rgba(255,255,255,0.15)';
                    btn.appendChild(bar);
                }
                container.appendChild(btn);
            });

            if (!anyVisible && game.totalTreats >= powerUps[0].unlockAt * 0.5) {
                const hint = document.createElement('div');
                hint.style.cssText = 'color:rgba(255,255,255,0.4);font-size:0.8rem;text-align:center;';
                hint.textContent = '⚡ Power-ups unlock at ' + formatNumber(powerUps[0].unlockAt) + ' total treats';
                container.appendChild(hint);
            }
        }

        function autoClickTick(delta) {
            if (powerUpState.autopet && powerUpState.autopet.active) {
                const earned = game.clickPower * 10 * delta;
                game.treats += earned;
                game.totalTreats += earned;
                game.lifetimeTreats += earned;
            }
        }

        // ===== Boss Fight =====
        let bossTickInterval = null;

        function getNextBoss() {
            const idx = Math.min(game.bossesDefeated, bossTypes.length - 1);
            const boss = bossTypes[idx];
            const scale = Math.pow(1.5, Math.max(0, game.bossesDefeated - bossTypes.length + 1));
            return {
                ...boss,
                hp: Math.floor(boss.hp * scale),
                reward: Math.floor(boss.reward * scale * game.prestigeMulti)
            };
        }

        function canFightBoss() {
            return game.totalTreats >= 5000 && !bossState.active && !miniState.active;
        }

        function startBossFight() {
            if (!canFightBoss()) return;
            initAudio();
            const boss = getNextBoss();
            bossState = { active: true, bossIndex: game.bossesDefeated, hp: boss.hp, maxHp: boss.hp, timer: boss.time, reward: boss.reward };

            document.getElementById('bossTitle').textContent = '⚔️ ' + boss.name + '! ⚔️';
            document.getElementById('bossSprite').textContent = boss.emoji;
            document.getElementById('bossHpFill').style.width = '100%';
            document.getElementById('bossHpText').textContent = 'HP: ' + formatNumber(boss.hp) + ' / ' + formatNumber(boss.hp);
            document.getElementById('bossTimer').textContent = boss.time + 's';
            document.getElementById('bossRewardText').textContent = 'Reward: ' + formatNumber(boss.reward) + ' treats!';
            document.getElementById('bossOverlay').classList.add('active');

            playSound(150, 0.5, 'sawtooth', 0.15);

            bossTickInterval = setInterval(() => {
                bossState.timer -= 0.1;
                document.getElementById('bossTimer').textContent = Math.ceil(bossState.timer) + 's';
                if (bossState.timer <= 0) endBossFight(false);
            }, 100);
        }

        function hitBoss() {
            if (!bossState.active) return;
            const dmg = getEffectiveClick();
            bossState.hp -= dmg;
            playBossHitSound();

            const sprite = document.getElementById('bossSprite');
            sprite.classList.remove('boss-hit');
            void sprite.offsetWidth;
            sprite.classList.add('boss-hit');

            const pct = Math.max(0, bossState.hp / bossState.maxHp * 100);
            document.getElementById('bossHpFill').style.width = pct + '%';
            document.getElementById('bossHpText').textContent = 'HP: ' + formatNumber(Math.max(0, bossState.hp)) + ' / ' + formatNumber(bossState.maxHp);

            if (bossState.hp <= 0) endBossFight(true);
        }

        function endBossFight(won) {
            clearInterval(bossTickInterval);
            bossState.active = false;
            if (won) {
                game.treats += bossState.reward;
                game.totalTreats += bossState.reward;
                game.lifetimeTreats += bossState.reward;
                game.bossesDefeated++;
                playBossDefeatSound();
                showGoldenReward(bossState.reward);
                screenShake();
                spawnTreatRain(20);
                showMilestone('⚔️ Boss Defeated! +' + formatNumber(bossState.reward) + ' treats!');
            } else {
                showMilestone('💀 Boss escaped! Try again...');
                playSound(100, 0.5, 'sawtooth', 0.1);
            }
            setTimeout(() => {
                document.getElementById('bossOverlay').classList.remove('active');
                updateDisplay();
                checkAchievements();
                checkWinCondition();
                renderEvents();
                saveGame();
            }, won ? 1000 : 500);
        }

        // ===== Mini-Game: Treat Catch =====
        function canPlayMinigame() {
            return game.totalTreats >= 1000 && !miniState.active && !bossState.active;
        }

        function startMinigame() {
            if (!canPlayMinigame()) return;
            initAudio();
            miniState = { active: true, timer: 15, caught: 0, interval: null, spawnInterval: null };
            document.getElementById('minigameOverlay').classList.add('active');
            document.getElementById('minigameArea').innerHTML = '';
            document.getElementById('minigameScore').textContent = 'Caught: 0';
            document.getElementById('minigameTimer').textContent = '15s';
            game.minigamesPlayed++;

            miniState.spawnInterval = setInterval(spawnMinigameTreat, 600);
            miniState.interval = setInterval(() => {
                miniState.timer -= 0.1;
                document.getElementById('minigameTimer').textContent = Math.ceil(miniState.timer) + 's';
                if (miniState.timer <= 0) endMinigame();
            }, 100);
        }

        function spawnMinigameTreat() {
            if (!miniState.active) return;
            const area = document.getElementById('minigameArea');
            const isBomb = Math.random() < 0.2;
            const el = document.createElement('div');
            el.className = isBomb ? 'falling-bomb' : 'falling-treat';
            el.textContent = isBomb ? '💣' : ['🦴', '🐾', '🎾', '⭐', '🍖'][Math.floor(Math.random() * 5)];
            el.style.left = (10 + Math.random() * 80) + '%';
            el.style.top = '-30px';

            let y = -30;
            const speed = 2 + Math.random() * 3;
            const drift = (Math.random() - 0.5) * 2;
            const moveInterval = setInterval(() => {
                if (!miniState.active) { clearInterval(moveInterval); el.remove(); return; }
                y += speed;
                const curLeft = parseFloat(el.style.left);
                el.style.top = y + 'px';
                el.style.left = (curLeft + drift * 0.1) + '%';
                if (y > 400) { clearInterval(moveInterval); el.remove(); }
            }, 16);

            el.onclick = () => {
                clearInterval(moveInterval);
                if (isBomb) {
                    miniState.caught = Math.max(0, miniState.caught - 3);
                    playSound(100, 0.3, 'sawtooth', 0.15);
                    el.textContent = '💥';
                    setTimeout(() => el.remove(), 200);
                } else {
                    miniState.caught++;
                    playSound(800 + miniState.caught * 20, 0.08, 'sine', 0.1);
                    el.textContent = '✨';
                    setTimeout(() => el.remove(), 150);
                }
                document.getElementById('minigameScore').textContent = 'Caught: ' + miniState.caught;
            };

            area.appendChild(el);
        }

        function endMinigame() {
            clearInterval(miniState.interval);
            clearInterval(miniState.spawnInterval);
            miniState.active = false;

            const reward = miniState.caught * game.clickPower * 5;
            game.treats += reward;
            game.totalTreats += reward;
            game.lifetimeTreats += reward;
            game.minigameTreats += reward;

            document.getElementById('minigameOverlay').classList.remove('active');
            if (miniState.caught > 0) {
                showGoldenReward(reward);
                showMilestone('🎮 Caught ' + miniState.caught + '! +' + formatNumber(reward) + ' treats!');
                playBossDefeatSound();
                spawnTreatRain(miniState.caught);
            } else {
                showMilestone('🎮 Better luck next time!');
            }
            updateDisplay();
            checkAchievements();
            checkWinCondition();
            renderEvents();
            saveGame();
        }

        // ===== Prestige / Rebirth =====
        function getPrestigeGain() {
            return Math.floor(Math.pow(game.totalTreats / 100000, 0.5));
        }

        function doPrestige() {
            const gain = getPrestigeGain();
            if (gain < 1) return;
            if (!confirm('Rebirth for +' + gain + ' prestige souls? (Currently: ' + game.prestige + ')\n\nYou keep: Prestige points, achievements, lifetime stats\nYou lose: Treats, upgrades, shop items')) return;

            game.prestige += gain;
            game.totalPrestiges++;
            game.prestigeMulti = 1 + game.prestige * 0.1;

            // Reset progress but keep meta
            game.treats = 0;
            game.totalTreats = 0;
            game.totalClicks = 0;
            game.upgrades = {};
            game.combo = 0;
            game.lastClickTime = 0;
            game.goldensCaught = 0;
            game.powerUpsUsed = 0;
            game.clickPower = 1;
            game.perSecond = 0;
            game.mood = 'Sleepy';
            game.moodMultiplier = 1;

            unlockedMilestones = new Set();
            powerUps.forEach(p => { powerUpState[p.id] = { active: false, cooldown: 0, remaining: 0 }; });

            recalcPerSecond();
            recalcClickPower();
            updateMood();
            updateDisplay();
            renderShop();
            renderPowerUps();
            renderPrestige();
            renderEvents();
            checkAchievements();
            spawnTreatRain(20);
            showMilestone('🔮 Reborn! x' + game.prestigeMulti.toFixed(1) + ' global multiplier!');
            playMilestoneSound();
            saveGame();
        }

        function renderPrestige() {
            const btn = document.getElementById('prestigeBtn');
            const info = document.getElementById('prestigeInfo');
            const gain = getPrestigeGain();

            if (game.totalTreats >= 50000 || game.prestige > 0) {
                btn.style.display = 'block';
                btn.textContent = '🔮 Rebirth (+' + gain + ' souls)';
                btn.style.opacity = gain >= 1 ? '1' : '0.5';
                info.textContent = '🔮 Prestige: ' + game.prestige + ' souls (x' + game.prestigeMulti.toFixed(1) + ' all)';
            } else {
                btn.style.display = 'none';
                info.textContent = '';
            }
        }

        // ===== Events Row (Boss / Mini-game buttons) =====
        function renderEvents() {
            const row = document.getElementById('eventsRow');
            row.innerHTML = '';

            if (game.totalTreats >= 1000 || game.lifetimeTreats >= 1000) {
                const miniBtn = document.createElement('button');
                miniBtn.className = 'event-btn' + (canPlayMinigame() ? '' : ' disabled-btn');
                miniBtn.textContent = '🎮 Mini-Game';
                miniBtn.onclick = () => startMinigame();
                row.appendChild(miniBtn);
            }

            if (game.totalTreats >= 5000 || game.lifetimeTreats >= 5000) {
                const bossBtn = document.createElement('button');
                const boss = getNextBoss();
                bossBtn.className = 'event-btn' + (canFightBoss() ? '' : ' disabled-btn');
                bossBtn.textContent = '⚔️ Boss: ' + boss.name;
                bossBtn.onclick = () => startBossFight();
                row.appendChild(bossBtn);
            }
        }

        // ===== Milestones =====
        function checkMilestones() {
            milestones.forEach(m => {
                if (!unlockedMilestones.has(m.at) && game.totalTreats >= m.at) {
                    unlockedMilestones.add(m.at);
                    showMilestone(m.msg);
                    playMilestoneSound();
                    screenShake();
                    spawnTreatRain(12);
                    recalcPerSecond();
                    recalcClickPower();
                }
            });
        }

        function showMilestone(msg) {
            const banner = document.getElementById('milestoneBanner');
            banner.textContent = msg;
            banner.classList.add('show');
            setTimeout(() => banner.classList.remove('show'), 4000);
        }

        // ===== Win Condition =====
        const WIN_GOAL = 1000000000; // 1 billion

        function checkWinCondition() {
            if (game.hasWon) return;
            const hasTicket = (game.upgrades['paradise_ticket'] || 0) >= 1;
            if (hasTicket && game.totalTreats >= WIN_GOAL) {
                triggerWin();
            }
        }

        function triggerWin() {
            game.hasWon = true;
            saveGame();
            initAudio();

            // Start journey cinematic, THEN show win screen
            playParadiseJourney(() => {
                playWinSound();

                const elapsed = Math.floor((Date.now() - game.startTime) / 1000);
                const hrs = Math.floor(elapsed / 3600);
                const mins = Math.floor((elapsed % 3600) / 60);
                const secs = elapsed % 60;
                const timeStr = (hrs > 0 ? hrs + 'h ' : '') + mins + 'm ' + secs + 's';

                const stats = document.getElementById('winStats');
                const statLines = [
                    '🦴 Total Treats: ' + formatNumber(game.lifetimeTreats || game.totalTreats),
                    '🐾 Total Clicks: ' + formatNumber(game.totalClicks),
                    '🛒 Total Upgrades: ' + getTotalUpgrades(),
                    '⚔️ Bosses Defeated: ' + game.bossesDefeated,
                    '🔮 Rebirths: ' + game.totalPrestiges,
                    '🔥 Max Combo: ' + game.maxCombo,
                    '✨ Golden Bones: ' + game.goldensCaught,
                    '🏆 Achievements: ' + unlockedAchievements.size + '/' + achievements.length,
                    '⏱️ Time: ' + timeStr
                ];
                stats.innerHTML = '<h3>📊 Final Stats</h3>' + statLines.map((line, i) =>
                    '<p style="animation-delay:' + (2.4 + i * 0.15) + 's">' + line + '</p>'
                ).join('');

                document.getElementById('winOverlay').classList.add('active');
                spawnTreatRain(30);
                startWinAnimations();
            });

            checkAchievements();
        }

        // ===== Treat World Journey Cinematic =====
        let journeyTrailInterval = null;

        function playParadiseJourney(onComplete) {
            const overlay = document.getElementById('journeyOverlay');
            const dog = document.getElementById('journeyDog');
            overlay.classList.add('active');

            // Build scenes
            buildCityScene();
            buildCloudScene();

            const scenes = [
                document.getElementById('journeyScene1'),
                document.getElementById('journeyScene2'),
                document.getElementById('journeyScene3'),
                document.getElementById('journeyScene4')
            ];
            const captions = [
                document.getElementById('journeyCaption1'),
                document.getElementById('journeyCaption2'),
                document.getElementById('journeyCaption3'),
                document.getElementById('journeyCaption4')
            ];

            // Timeline
            let t = 0;

            // Scene 1: Home - Linda sees a treat glow and walks toward it
            scenes[0].classList.add('visible');
            dog.className = 'journey-dog walking';
            dog.style.top = 'auto';
            dog.style.bottom = '42%';
            dog.style.left = '-60px';
            setTimeout(() => { dog.style.left = '50%'; }, 100);
            setTimeout(() => { captions[0].classList.add('visible'); }, 800);
            // Dreamy sound
            playSound(330, 2, 'sine', 0.04);
            setTimeout(() => playSound(440, 2, 'sine', 0.04), 500);
            t += 3500;

            // Scene 2: Treat trail path - dog walks along the path
            setTimeout(() => {
                scenes[0].classList.remove('visible');
                captions[0].classList.remove('visible');
                scenes[1].classList.add('visible');
                dog.className = 'journey-dog walking';
                dog.style.top = 'auto';
                dog.style.bottom = '33%';
                dog.style.left = '10%';
                // Start sparkle trail
                startJourneyTrail(dog);
                setTimeout(() => {
                    dog.style.left = '80%';
                }, 200);
                setTimeout(() => { captions[1].classList.add('visible'); }, 600);
                // Whimsical sound
                playSound(392, 1.5, 'sine', 0.06);
                setTimeout(() => playSound(523, 1, 'sine', 0.06), 300);
            }, t);
            t += 3500;

            // Scene 3: Treat World gates - dog walks toward the gate
            setTimeout(() => {
                scenes[1].classList.remove('visible');
                captions[1].classList.remove('visible');
                scenes[2].classList.add('visible');
                dog.className = 'journey-dog walking';
                dog.style.top = 'auto';
                dog.style.bottom = '15%';
                dog.style.left = '-10%';
                setTimeout(() => {
                    dog.style.left = '50%';
                }, 300);
                setTimeout(() => { captions[2].classList.add('visible'); }, 600);
                // Gate opening sound
                playSound(523, 1.5, 'sine', 0.1);
                setTimeout(() => playSound(659, 1, 'triangle', 0.1), 400);
                setTimeout(() => playSound(784, 1.5, 'sine', 0.1), 800);
            }, t);
            t += 3500;

            // Scene 4: Treat World - dog walks into the world
            setTimeout(() => {
                scenes[2].classList.remove('visible');
                captions[2].classList.remove('visible');
                buildTreatWorldScene();
                scenes[3].classList.add('visible');
                dog.className = 'journey-dog walking';
                dog.style.top = 'auto';
                dog.style.bottom = '22%';
                dog.style.left = '-10%';
                setTimeout(() => {
                    dog.style.left = '50%';
                }, 300);
                setTimeout(() => { captions[3].classList.add('visible'); }, 1000);
                // Treat World jingle
                [523, 659, 784, 1047].forEach((f, i) => setTimeout(() => playSound(f, 0.5, 'triangle', 0.08), i * 200));
            }, t);
            t += 4000;

            // Fade out journey and trigger win
            setTimeout(() => {
                stopJourneyTrail();
                overlay.style.transition = 'opacity 1.5s ease';
                overlay.style.opacity = '0';
                setTimeout(() => {
                    overlay.classList.remove('active');
                    overlay.style.opacity = '';
                    overlay.style.transition = '';
                    scenes.forEach(s => s.classList.remove('visible'));
                    captions.forEach(c => c.classList.remove('visible'));
                    dog.className = 'journey-dog';
                    dog.style = '';
                    onComplete();
                }, 1500);
            }, t);
        }

        function buildCityScene() {
            // Scene 1 is now static HTML (home with treat jars), just build stars
            const starsEl = document.getElementById('journeyStars');
            starsEl.innerHTML = '';
            for (let i = 0; i < 30; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.animationDelay = Math.random() * 2 + 's';
                star.style.width = (2 + Math.random() * 3) + 'px';
                star.style.height = star.style.width;
                starsEl.appendChild(star);
            }
        }

        function buildCloudScene() {
            const container = document.getElementById('journeyClouds');
            container.innerHTML = '';
            // Add a few clouds in the sky
            const cloudData = [
                { w: 150, h: 40, x: '10%', y: '8%', delay: '0s' },
                { w: 180, h: 50, x: '55%', y: '5%', delay: '1s' },
                { w: 120, h: 35, x: '80%', y: '15%', delay: '0.5s' },
            ];
            cloudData.forEach(c => {
                const el = document.createElement('div');
                el.className = 'cloud';
                el.style.width = c.w + 'px';
