                milestones: Array.from(unlockedMilestones),
                goldensCaught: game.goldensCaught, powerUpsUsed: game.powerUpsUsed,
                maxCombo: game.maxCombo, prestige: game.prestige,
                prestigeMulti: game.prestigeMulti, totalPrestiges: game.totalPrestiges,
                bossesDefeated: game.bossesDefeated, minigamesPlayed: game.minigamesPlayed,
                minigameTreats: game.minigameTreats, hasWon: game.hasWon,
                lifetimeTreats: game.lifetimeTreats,
                adminPerSecBonus: game.adminPerSecBonus || 0
            };
            localStorage.setItem(getSaveKey(), JSON.stringify(data));
        }

        function loadGame() {
            const raw = localStorage.getItem(getSaveKey());
            if (!raw) return;
            try {
                const d = JSON.parse(raw);
                game.treats = d.treats || 0;
                game.totalTreats = d.totalTreats || 0;
                game.totalClicks = d.totalClicks || 0;
                game.upgrades = d.upgrades || {};
                game.startTime = d.startTime || Date.now();
                game.goldensCaught = d.goldensCaught || 0;
                game.powerUpsUsed = d.powerUpsUsed || 0;
                game.maxCombo = d.maxCombo || 0;
                game.prestige = d.prestige || 0;
                game.prestigeMulti = d.prestigeMulti || 1;
                game.totalPrestiges = d.totalPrestiges || 0;
                game.bossesDefeated = d.bossesDefeated || 0;
                game.minigamesPlayed = d.minigamesPlayed || 0;
                game.minigameTreats = d.minigameTreats || 0;
                game.hasWon = d.hasWon || false;
                game.lifetimeTreats = d.lifetimeTreats || d.totalTreats || 0;
                game.adminPerSecBonus = d.adminPerSecBonus || 0;
                unlockedAchievements = new Set(d.achievements || []);
                unlockedMilestones = new Set((d.milestones || []).map(Number));
                recalcPerSecond();
                recalcClickPower();
            } catch (e) { console.warn('Failed to load:', e); }
        }

        function resetGame() {
            if (!confirm('Are you sure? ALL progress will be lost, including prestige!')) return;
            localStorage.removeItem(getSaveKey());
            game = {
                treats: 0, totalTreats: 0, totalClicks: 0, clickPower: 1, perSecond: 0,
                startTime: Date.now(), upgrades: {}, combo: 0, maxCombo: 0, lastClickTime: 0,
                moodMultiplier: 1, mood: 'Sleepy', goldensCaught: 0, powerUpsUsed: 0,
                prestige: 0, prestigeMulti: 1, totalPrestiges: 0,
                bossesDefeated: 0, minigamesPlayed: 0, minigameTreats: 0,
                hasWon: false, lifetimeTreats: 0
            };
            unlockedAchievements = new Set();
            unlockedMilestones = new Set();
            powerUps.forEach(p => { powerUpState[p.id] = { active: false, cooldown: 0, remaining: 0 }; });
            updateMood();
            updateDisplay();
            renderShop();
            renderPowerUps();
            renderPrestige();
            renderEvents();
            updateProgressBar();
        }

        // ===== Background Bones =====
        function createBackgroundBones() {
            const container = document.getElementById('bgBones');
            const bones = ['🦴', '🐾', '🎾', '🐕', '❤️', '⭐'];
            for (let i = 0; i < 15; i++) {
                const bone = document.createElement('div');
                bone.className = 'bg-bone';
                bone.textContent = bones[Math.floor(Math.random() * bones.length)];
                bone.style.left = Math.random() * 100 + 'vw';
                bone.style.animationDuration = (10 + Math.random() * 20) + 's';
                bone.style.animationDelay = (Math.random() * 15) + 's';
                bone.style.fontSize = (20 + Math.random() * 30) + 'px';
                container.appendChild(bone);
            }
        }

        // ===== Auto-save =====
        setInterval(() => { if (currentUser) saveGame(); }, 30000);

        // ===== Init =====
        initAdminAccount();
        createBackgroundBones();
        scheduleGoldenBone();
        requestAnimationFrame(gameLoop);

        // Allow Enter key to submit login
        document.getElementById('authPassword').addEventListener('keydown', (e) => { if (e.key === 'Enter') authAction(); });
        document.getElementById('authUsername').addEventListener('keydown', (e) => { if (e.key === 'Enter') document.getElementById('authPassword').focus(); });

        // Auto-login if session exists
        (function autoLogin() {
            const lastUser = localStorage.getItem('dogClickerCurrentUser');
            if (lastUser) {
                const accounts = getAccounts();
                if (accounts[lastUser]) {
                    loginAs(lastUser, accounts[lastUser]);
                    return;
                }
            }
            // Show login screen (it's visible by default)
        })();
    </script>
</body>
</html>
